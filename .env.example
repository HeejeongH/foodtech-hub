# DART OpenAPI key (한국 상장기업 재무 데이터)
# https://opendart.fss.or.kr/uss/umt/EgovMberInsertView.do 에서 무료 발급
DART_API_KEY=

# Brave Search API key (뉴스 자동 크롤링, 월 2,000회 무료)
# https://api.search.brave.com/app/keys 에서 발급
# 없으면 자동으로 Google News RSS로 폴백
BRAVE_API_KEY=

# 캐시 디렉터리 (영속 볼륨)
DATA_DIR=/app/data

# 서버 포트 (Railway/Render는 자동 주입)
PORT=8000
